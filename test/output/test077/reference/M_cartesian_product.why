theory B_translation
  use bool.Bool
  use int.Int
  use int.Power
  use int.ComputerDivision
    (* See B-Book, section 3.5.7-Arithmetic, Division, p. 164
       and section 3.6-Integers, table p. 173 *)

  use bpo2why_prelude.B_BOOL
  use real.Real
  use bpo2why_prelude.B_REAL
  use bpo2why_prelude.Interval
  use bpo2why_prelude.PowerSet
  use bpo2why_prelude.Relation
  use bpo2why_prelude.Image
  use bpo2why_prelude.Identity
  use bpo2why_prelude.InverseDomRan
  use bpo2why_prelude.Function
  use bpo2why_prelude.Sequence
  use bpo2why_prelude.IsFinite
  use bpo2why_prelude.PowerRelation
  use bpo2why_prelude.Restriction
  use bpo2why_prelude.Overriding
  use bpo2why_prelude.Composition
  use bpo2why_prelude.BList
  use bpo2why_prelude.MinMax
  use bpo2why_prelude.Projection
  use bpo2why_prelude.Iteration
  use bpo2why_prelude.Generalized





predicate define1  =
   true /\
(nat == (Interval.mk 0 b_maxint32_value)) /\
(bounded_int == (Interval.mk b_minint32_value b_maxint32_value))



predicate define2  =
   true



predicate define3  =
   true



predicate define4 (v_s0_: (set int))(v_s1_: (set int))(v_c0_: (int,int)) =
   true /\
(mem v_s0_ (power integer)) /\
(mem v_s1_ (power integer)) /\
(mem v_c0_ (times integer integer))



predicate define5  =
   true



predicate define6  =
   true



predicate define7  =
   true


function anon_set_1 : (set int)

axiom anon_set_1_def :
forall v_xx_: int .
 mem (v_xx_)(anon_set_1 ) <-> (mem v_xx_ integer) /\ ((mod v_xx_ 2) = 0)


predicate define8 (v_c0_: (int,int))(v_s0_: (set int))(v_s1_: (set int)) =
   true /\
(mem v_c0_ (times v_s0_ v_s1_)) /\
(mem (2 , 5) (times (union (singleton 2) (union (singleton 5) (singleton 7))) (Interval.mk 0 10))) /\
(mem (2 , 0) (times (anon_set_1 ) (singleton 0)))



predicate define9  =
   true



predicate define10  =
   true




predicate lh_0_0  =
   true



goal g_0 :
   forall v_s0_: (set int), v_s1_: (set int), v_c0_: (int,int).
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_s0_ v_s1_ v_c0_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_0_0 )
   -> 
   true /\
(mem v_c0_ (times v_s0_ v_s1_))



predicate lh_1_0 (v_c0_: (int,int))(v_s0_: (set int))(v_s1_: (set int)) =
   true /\
(mem v_c0_ (times v_s0_ v_s1_))



goal g_1 :
   forall v_s0_: (set int), v_s1_: (set int), v_c0_: (int,int).
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_s0_ v_s1_ v_c0_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_1_0 v_c0_ v_s0_ v_s1_)
   -> 
   true /\
(mem (2 , 5) (times (union (singleton 2) (union (singleton 5) (singleton 7))) (Interval.mk 0 10)))



predicate lh_2_0 (v_c0_: (int,int))(v_s0_: (set int))(v_s1_: (set int)) =
   true /\
(mem v_c0_ (times v_s0_ v_s1_))


function anon_set_2 : (set int)

axiom anon_set_2_def :
forall v_xx_: int .
 mem (v_xx_)(anon_set_2 ) <-> (mem v_xx_ integer) /\ ((mod v_xx_ 2) = 0)

goal g_2 :
   forall v_s0_: (set int), v_s1_: (set int), v_c0_: (int,int).
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_s0_ v_s1_ v_c0_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_2_0 v_c0_ v_s0_ v_s1_)
   -> 
   true /\
(mem (2 , 0) (times (anon_set_2 ) (singleton 0)))


end
