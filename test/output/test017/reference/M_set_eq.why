theory B_translation
  use bool.Bool
  use int.Int
  use int.Power
  use int.ComputerDivision
    (* See B-Book, section 3.5.7-Arithmetic, Division, p. 164
       and section 3.6-Integers, table p. 173 *)

  use bpo2why_prelude.B_BOOL
  use real.Real
  use bpo2why_prelude.B_REAL
  use bpo2why_prelude.Interval
  use bpo2why_prelude.PowerSet
  use bpo2why_prelude.Relation
  use bpo2why_prelude.Image
  use bpo2why_prelude.Identity
  use bpo2why_prelude.InverseDomRan
  use bpo2why_prelude.Function
  use bpo2why_prelude.Sequence
  use bpo2why_prelude.IsFinite
  use bpo2why_prelude.PowerRelation
  use bpo2why_prelude.Restriction
  use bpo2why_prelude.Overriding
  use bpo2why_prelude.Composition
  use bpo2why_prelude.BList
  use bpo2why_prelude.MinMax
  use bpo2why_prelude.Projection
  use bpo2why_prelude.Iteration
  use bpo2why_prelude.Generalized





predicate define1  =
   true /\
(nat == (Interval.mk 0 b_maxint32_value)) /\
(bounded_int == (Interval.mk b_minint32_value b_maxint32_value))



predicate define2  =
   true



predicate define3  =
   true


function anon_lambda_1 : set((int),int)

axiom anon_lambda_1_def :
forall v_xx_: int .
(mem v_xx_ integer)
-> (apply (anon_lambda_1 ) (v_xx_)) = (v_xx_ * 2)

function anon_set_1 : (set int)

axiom anon_set_1_def :
forall v_xx_: int .
 mem (v_xx_)(anon_set_1 ) <-> (mem v_xx_ integer) /\ ((mod v_xx_ 2) = 0)


predicate define4 (v_double_: (set (int,int)))(v_pairs1_: (set int))(v_pairs2_: (set int)) =
   true /\
(mem v_double_ (relation integer integer)) /\
(v_double_ == (anon_lambda_1 )) /\
(mem v_pairs1_ (power integer)) /\
(mem v_pairs2_ (power integer)) /\
(v_pairs1_ == (ran v_double_)) /\
(v_pairs2_ == (anon_set_1 ))



predicate define5  =
   true



predicate define6  =
   true



predicate define7  =
   true



predicate define8 (v_pairs1_: (set int))(v_pairs2_: (set int)) =
   true /\
(v_pairs1_ == v_pairs2_)



predicate define9  =
   true



predicate define10  =
   true




predicate lh_0_0  =
   true



goal g_0 :
   forall v_double_: (set (int,int)), v_pairs1_: (set int), v_pairs2_: (set int).
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_double_ v_pairs1_ v_pairs2_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_0_0 )
   -> 
   true /\
(v_pairs1_ == v_pairs2_)


end
