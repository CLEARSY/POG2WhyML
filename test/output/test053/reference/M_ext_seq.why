  use bpo2why_prelude.PowerRelation
  use bpo2why_prelude.Restriction
  use bpo2why_prelude.Overriding
  use bpo2why_prelude.Composition
  use bpo2why_prelude.BList
  use bpo2why_prelude.MinMax
  use bpo2why_prelude.Projection
  use bpo2why_prelude.Iteration
  use bpo2why_prelude.Generalized





predicate define1  =
   true /\
(nat == (Interval.mk 0 b_maxint32_value)) /\
(bounded_int == (Interval.mk b_minint32_value b_maxint32_value))



predicate define2  =
   true



predicate define3  =
   true



predicate define4 (v_empty_seq_: (set (int,int)))(v_ss_: (set (int,int)))(v_c0_: int)(v_ii_: int) =
   true /\
(mem v_empty_seq_ (seq integer)) /\
(v_empty_seq_ == (empty : (set (int,int)))) /\
(mem v_ss_ (seq integer)) /\
(mem v_c0_ integer) /\
(mem v_ii_ natural)



predicate define5  =
   true



predicate define6  =
   true



predicate define7  =
   true



predicate define8 (v_empty_seq_: (set (int,int)))(v_ii_: int)(v_c0_: int)(v_ss_: (set (int,int))) =
   true /\
(mem (2 , 4) (union (singleton (1, 5)) (union (singleton (2, 4)) (union (singleton (3, 1)) (union (singleton (4, 1)) (union (singleton (5, 2)) (union (singleton (6, 3)) (singleton (7, 8))))))))) /\
(mem (1 , 6) v_empty_seq_) /\
(mem (v_ii_ , v_c0_) v_ss_)



predicate define9  =
   true



predicate define10  =
   true




predicate lh_0_0  =
   true



goal g_0 :
   forall v_empty_seq_: (set (int,int)), v_ss_: (set (int,int)), v_c0_: int, v_ii_: int.
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_empty_seq_ v_ss_ v_c0_ v_ii_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_0_0 )
   -> 
   true /\
(mem (2 , 4) (union (singleton (1, 5)) (union (singleton (2, 4)) (union (singleton (3, 1)) (union (singleton (4, 1)) (union (singleton (5, 2)) (union (singleton (6, 3)) (singleton (7, 8)))))))))



predicate lh_1_0  =
   true /\
(mem (2 , 4) (union (singleton (1, 5)) (union (singleton (2, 4)) (union (singleton (3, 1)) (union (singleton (4, 1)) (union (singleton (5, 2)) (union (singleton (6, 3)) (singleton (7, 8)))))))))



goal g_1 :
   forall v_empty_seq_: (set (int,int)), v_ss_: (set (int,int)), v_c0_: int, v_ii_: int.
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_empty_seq_ v_ss_ v_c0_ v_ii_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_1_0 )
   -> 
   true /\
(mem (1 , 6) v_empty_seq_)



predicate lh_2_0  =
   true /\
(mem (2 , 4) (union (singleton (1, 5)) (union (singleton (2, 4)) (union (singleton (3, 1)) (union (singleton (4, 1)) (union (singleton (5, 2)) (union (singleton (6, 3)) (singleton (7, 8)))))))))



goal g_2 :
   forall v_empty_seq_: (set (int,int)), v_ss_: (set (int,int)), v_c0_: int, v_ii_: int.
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_empty_seq_ v_ss_ v_c0_ v_ii_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_2_0 )
   -> 
   true /\
(mem (v_ii_ , v_c0_) v_ss_)


end
