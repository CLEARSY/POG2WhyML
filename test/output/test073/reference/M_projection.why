predicate define8 (v_ss_: (set int))(v_c0_: int)(v_c1_: int)(v_c2_: int)(v_s0_: (set int))(v_s1_: (set int)) =
   true /\
(mem ((10 , 5) , 5) (prj1 v_ss_ (Interval.mk 0 5))) /\
(mem ((v_c0_ , v_c1_) , v_c2_) (prj1 v_s0_ v_s1_)) /\
(mem ((10 , 5) , 10) (prj2 v_ss_ (Interval.mk 0 5))) /\
(mem ((v_c0_ , v_c1_) , v_c2_) (prj2 v_s0_ v_s1_))



