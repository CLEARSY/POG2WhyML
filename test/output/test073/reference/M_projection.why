predicate define1  =
   true /\
(nat == (Interval.mk 0 b_maxint32_value)) /\
(bounded_int == (Interval.mk b_minint32_value b_maxint32_value))



predicate define2  =
   true



predicate define3  =
   true


function anon_set_1 : (set int)

axiom anon_set_1_def :
forall v_xx_: int .
 mem (v_xx_)(anon_set_1 ) <-> (mem v_xx_ (Interval.mk 0 10)) /\ ((mod v_xx_ 2) = 0)


predicate define4 (v_s0_: (set int))(v_s1_: (set int))(v_rr_: (set (int,int)))(v_ss_: (set int))(v_c0_: int)(v_c1_: int)(v_c2_: int) =
   true /\
(mem v_s0_ (power integer)) /\
(mem v_s1_ (power v_s0_)) /\
(mem v_rr_ (relation v_s0_ v_s1_)) /\
(mem v_ss_ (power integer)) /\
(v_ss_ == (anon_set_1 )) /\
(mem v_c0_ integer) /\
(mem v_c1_ integer) /\
(mem v_c2_ integer)



