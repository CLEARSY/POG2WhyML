  use bpo2why_prelude.MinMax
  use bpo2why_prelude.Projection
  use bpo2why_prelude.Iteration
  use bpo2why_prelude.Generalized





predicate define1  =
   true /\
(nat == (Interval.mk 0 b_maxint32_value)) /\
(bounded_int == (Interval.mk b_minint32_value b_maxint32_value))



predicate define2  =
   true



predicate define3  =
   true


function anon_lambda_1 : set((int),int)

axiom anon_lambda_1_def :
forall v_xx_: int .
(mem v_xx_ (Interval.mk 0 2))
-> (apply (anon_lambda_1 ) (v_xx_)) = (v_xx_ * 2)


predicate define4 (v_ff_: (set (int,int))) =
   true /\
(v_ff_ == (anon_lambda_1 ))



predicate define5  =
   true



predicate define6  =
   true



predicate define7  =
   true



predicate define8 (v_ff_: (set (int,int))) =
   true /\
((singleton (3 , 4)) == v_ff_)



predicate define9  =
   true



predicate define10  =
   true




predicate lh_0_0  =
   true



goal g_0 :
   forall v_ff_: (set (int,int)).
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_ff_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_0_0 )
   -> 
   true /\
((singleton (3 , 4)) == v_ff_)


end
