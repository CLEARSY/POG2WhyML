predicate define1  =
   true /\
(nat == (Interval.mk 0 b_maxint32_value)) /\
(bounded_int == (Interval.mk b_minint32_value b_maxint32_value))



predicate define2  =
   true



predicate define3  =
   true


function anon_set_1 : (set (int,int))

axiom anon_set_1_def :
forall v_xx_: int, v_yy_: int .
 mem ((v_xx_),v_yy_)(anon_set_1 ) <-> (mem v_xx_ (Interval.mk 0 10)) /\ (mem v_yy_ integer) /\ ((v_xx_ + v_yy_) = 15)


predicate define4 (v_s0_: (set int))(v_s1_: (set int))(v_rr_: (set (int,int)))(v_ss_: (set (int,int)))(v_tt_: (set (int,int)))(v_uu_: (set (int,real)))(v_c0_: int)(v_c1_: int)(v_c2_: int)(v_c3_: real) =
   true /\
(mem v_s0_ (power integer)) /\
(mem v_s1_ (power integer)) /\
(mem v_rr_ (relation v_s0_ v_s1_)) /\
(mem v_ss_ (relation integer integer)) /\
(v_ss_ == (anon_set_1 )) /\
(mem v_tt_ (relation integer integer)) /\
(v_tt_ == (union (singleton (2 , 7)) (union (singleton (5 , 9)) (union (singleton (2 , 6)) (union (singleton (7 , 9)) (singleton (5 , 3))))))) /\
(mem v_uu_ (relation v_s1_ b_real)) /\
(mem v_c0_ integer) /\
(mem v_c1_ integer) /\
(mem v_c2_ integer) /\
(mem v_c3_ b_real)



