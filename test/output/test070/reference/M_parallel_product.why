predicate define8 (v_ss_: (set (int,int)))(v_tt_: (set (int,int)))(v_c0_: int)(v_c1_: int)(v_c2_: int)(v_c3_: real)(v_rr_: (set (int,int)))(v_uu_: (set (int,real))) =
   true /\
(mem ((10 , (-2)) , (5 , 2)) (parallel_product v_ss_ v_tt_)) /\
(mem ((v_c0_ , v_c1_) , (v_c2_ , v_c3_)) (parallel_product v_rr_ v_uu_))



predicate define9  =
   true



predicate define10  =
   true




predicate lh_0_0  =
   true



goal g_0 :
   forall v_s0_: (set int), v_s1_: (set int), v_rr_: (set (int,int)), v_ss_: (set (int,int)), v_tt_: (set (int,int)), v_uu_: (set (int,real)), v_c0_: int, v_c1_: int, v_c2_: int, v_c3_: real.
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_s0_ v_s1_ v_rr_ v_ss_ v_tt_ v_uu_ v_c0_ v_c1_ v_c2_ v_c3_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_0_0 )
   -> 
   true /\
(mem ((10 , (-2)) , (5 , 2)) (parallel_product v_ss_ v_tt_))



predicate lh_1_0 (v_ss_: (set (int,int)))(v_tt_: (set (int,int))) =
   true /\
(mem ((10 , (-2)) , (5 , 2)) (parallel_product v_ss_ v_tt_))



goal g_1 :
   forall v_s0_: (set int), v_s1_: (set int), v_rr_: (set (int,int)), v_ss_: (set (int,int)), v_tt_: (set (int,int)), v_uu_: (set (int,real)), v_c0_: int, v_c1_: int, v_c2_: int, v_c3_: real.
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_s0_ v_s1_ v_rr_ v_ss_ v_tt_ v_uu_ v_c0_ v_c1_ v_c2_ v_c3_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_1_0 v_ss_ v_tt_)
   -> 
   true /\
(mem ((v_c0_ , v_c1_) , (v_c2_ , v_c3_)) (parallel_product v_rr_ v_uu_))


