theory B_translation
  use bool.Bool
  use int.Int
  use int.Power
  use int.ComputerDivision
    (* See B-Book, section 3.5.7-Arithmetic, Division, p. 164
       and section 3.6-Integers, table p. 173 *)

  use bpo2why_prelude.B_BOOL
  use real.Real
  use bpo2why_prelude.B_REAL
  use bpo2why_prelude.Interval
  use bpo2why_prelude.PowerSet
  use bpo2why_prelude.Relation
  use bpo2why_prelude.Image
  use bpo2why_prelude.Identity
  use bpo2why_prelude.InverseDomRan
  use bpo2why_prelude.Function
  use bpo2why_prelude.Sequence
  use bpo2why_prelude.IsFinite
  use bpo2why_prelude.PowerRelation
  use bpo2why_prelude.Restriction
  use bpo2why_prelude.Overriding
  use bpo2why_prelude.Composition
  use bpo2why_prelude.BList
  use bpo2why_prelude.MinMax
  use bpo2why_prelude.Projection
  use bpo2why_prelude.Iteration
  use bpo2why_prelude.Generalized





predicate define1  =
   true /\
(nat == (Interval.mk 0 b_maxint32_value)) /\
(bounded_int == (Interval.mk b_minint32_value b_maxint32_value))



predicate define2  =
   true



predicate define3  =
   true



predicate define4 (v_rel1_: (set (int,(set int))))(v_fun1_: (set (int,(set int))))(v_c0_: int)(v_c1_: int) =
   true /\
(v_rel1_ == (union (singleton (2 , (union (singleton 7) (singleton 5)))) (union (singleton (5 , (singleton 7))) (union (singleton (2 , (singleton 6))) (singleton (7 , (empty : (set int)))))))) /\
(mem v_fun1_ (relation integer (power integer))) /\
(mem v_c0_ integer) /\
(mem v_c1_ integer)



predicate define5  =
   true



predicate define6  =
   true



predicate define7  =
   true



predicate define8 (v_c0_: int)(v_fun1_: (set (int,(set int))))(v_c1_: int)(v_rel1_: (set (int,(set int)))) =
   true /\
(mem v_c0_ (apply v_fun1_ v_c1_)) /\
(mem 2 (apply v_rel1_ 2))



predicate define9  =
   true



predicate define10  =
   true




predicate lh_0_0  =
   true



goal g_0 :
   forall v_rel1_: (set (int,(set int))), v_fun1_: (set (int,(set int))), v_c0_: int, v_c1_: int.
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_rel1_ v_fun1_ v_c0_ v_c1_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_0_0 )
   -> 
   true /\
(mem v_c0_ (apply v_fun1_ v_c1_))



predicate lh_1_0 (v_c0_: int)(v_fun1_: (set (int,(set int))))(v_c1_: int) =
   true /\
(mem v_c0_ (apply v_fun1_ v_c1_))



goal g_1 :
   forall v_rel1_: (set (int,(set int))), v_fun1_: (set (int,(set int))), v_c0_: int, v_c1_: int.
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_rel1_ v_fun1_ v_c0_ v_c1_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_1_0 v_c0_ v_fun1_ v_c1_)
   -> 
   true /\
(mem 2 (apply v_rel1_ 2))


end
