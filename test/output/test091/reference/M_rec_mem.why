  use bpo2why_prelude.MinMax
  use bpo2why_prelude.Projection
  use bpo2why_prelude.Iteration
  use bpo2why_prelude.Generalized





predicate define1  =
   true /\
(nat == (Interval.mk 0 b_maxint32_value)) /\
(bounded_int == (Interval.mk b_minint32_value b_maxint32_value))



predicate define2  =
   true



predicate define3  =
   true

type type_struct_0 = {l_Mark_0 : (set int);l_good_enough_0 : (set bool)}
function anon_struct_0 : (set type_struct_0)
axiom anon_struct_0_def : forall p_Mark : (set int), p_good_enough : (set bool). mem {l_Mark_0 = p_Mark;l_good_enough_0 = p_good_enough} (anon_struct_0 ) <-> (mem p_Mark (power (Interval.mk 0 20)) /\ mem p_good_enough (power b_bool))

function anon_lambda_1 : set(((set int)),type_struct_0)

axiom anon_lambda_1_def :
forall v_notes_: (set int) .
(mem v_notes_ (power (Interval.mk 0 20)))
-> (apply (anon_lambda_1 ) (v_notes_)) = {l_Mark_0 = v_notes_; l_good_enough_0 = (singleton True)}


predicate define4 (v_res_set_: (set type_struct_0))(v_get_res_set_: (set ((set int),type_struct_0)))(v_ii_: int)(v_bb_: bool) =
   true /\
(v_res_set_ == (anon_struct_0 )) /\
(mem v_get_res_set_ ((power (Interval.mk 0 20)) --> v_res_set_)) /\
(v_get_res_set_ == (anon_lambda_1 )) /\
(mem v_ii_ integer) /\
(mem v_bb_ b_bool)



predicate define5  =
   true



predicate define6  =
   true



predicate define7  =
   true



predicate define8 (v_ii_: int)(v_get_res_set_: (set ((set int),type_struct_0)))(v_bb_: bool) =
   true /\
(mem v_ii_ ((apply v_get_res_set_ (Interval.mk 0 v_ii_)).l_Mark_0)) /\
(mem 12 ((apply v_get_res_set_ (singleton 12)).l_Mark_0)) /\
(mem v_bb_ ((apply v_get_res_set_ (Interval.mk 0 v_ii_)).l_good_enough_0)) /\
(mem True ((apply v_get_res_set_ (Interval.mk 0 v_ii_)).l_good_enough_0))



predicate define9  =
   true



predicate define10  =
   true




predicate lh_0_0  =
   true



goal g_0 :
   forall v_res_set_: (set type_struct_0), v_get_res_set_: (set ((set int),type_struct_0)), v_ii_: int, v_bb_: bool.
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_res_set_ v_get_res_set_ v_ii_ v_bb_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_0_0 )
   -> 
   true /\
(mem v_ii_ ((apply v_get_res_set_ (Interval.mk 0 v_ii_)).l_Mark_0))



predicate lh_1_0 (v_ii_: int)(v_get_res_set_: (set ((set int),type_struct_0))) =
   true /\
(mem v_ii_ ((apply v_get_res_set_ (Interval.mk 0 v_ii_)).l_Mark_0))



goal g_1 :
   forall v_res_set_: (set type_struct_0), v_get_res_set_: (set ((set int),type_struct_0)), v_ii_: int, v_bb_: bool.
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_res_set_ v_get_res_set_ v_ii_ v_bb_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_1_0 v_ii_ v_get_res_set_)
   -> 
   true /\
(mem 12 ((apply v_get_res_set_ (singleton 12)).l_Mark_0))



predicate lh_2_0 (v_ii_: int)(v_get_res_set_: (set ((set int),type_struct_0))) =
   true /\
(mem v_ii_ ((apply v_get_res_set_ (Interval.mk 0 v_ii_)).l_Mark_0))



goal g_2 :
   forall v_res_set_: (set type_struct_0), v_get_res_set_: (set ((set int),type_struct_0)), v_ii_: int, v_bb_: bool.
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_res_set_ v_get_res_set_ v_ii_ v_bb_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_2_0 v_ii_ v_get_res_set_)
   -> 
   true /\
(mem v_bb_ ((apply v_get_res_set_ (Interval.mk 0 v_ii_)).l_good_enough_0))



predicate lh_3_0 (v_ii_: int)(v_get_res_set_: (set ((set int),type_struct_0))) =
   true /\
(mem v_ii_ ((apply v_get_res_set_ (Interval.mk 0 v_ii_)).l_Mark_0))



goal g_3 :
   forall v_res_set_: (set type_struct_0), v_get_res_set_: (set ((set int),type_struct_0)), v_ii_: int, v_bb_: bool.
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_res_set_ v_get_res_set_ v_ii_ v_bb_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_3_0 v_ii_ v_get_res_set_)
   -> 
