theory B_translation
  use bool.Bool
  use int.Int
  use int.Power
  use int.ComputerDivision
    (* See B-Book, section 3.5.7-Arithmetic, Division, p. 164
       and section 3.6-Integers, table p. 173 *)

  use bpo2why_prelude.B_BOOL
  use real.Real
  use bpo2why_prelude.B_REAL
  use bpo2why_prelude.Interval
  use bpo2why_prelude.PowerSet
  use bpo2why_prelude.Relation
  use bpo2why_prelude.Image
  use bpo2why_prelude.Identity
  use bpo2why_prelude.InverseDomRan
  use bpo2why_prelude.Function
  use bpo2why_prelude.Sequence
  use bpo2why_prelude.IsFinite
  use bpo2why_prelude.PowerRelation
  use bpo2why_prelude.Restriction
  use bpo2why_prelude.Overriding
  use bpo2why_prelude.Composition
  use bpo2why_prelude.BList
  use bpo2why_prelude.MinMax
  use bpo2why_prelude.Projection
  use bpo2why_prelude.Iteration
  use bpo2why_prelude.Generalized





predicate define1  =
   true /\
(nat == (Interval.mk 0 b_maxint32_value)) /\
(bounded_int == (Interval.mk b_minint32_value b_maxint32_value))



predicate define2  =
   true



predicate define3  =
   true


function anon_set_1 : (set int)

axiom anon_set_1_def :
forall v_xx_: int .
 mem (v_xx_)(anon_set_1 ) <-> (mem v_xx_ integer) /\ (v_xx_ < 10)

function anon_set_2 : (set int)

axiom anon_set_2_def :
forall v_xx_: int .
 mem (v_xx_)(anon_set_2 ) <-> (mem v_xx_ integer) /\ ((mod v_xx_ 2) = 0)


predicate define4 (v_S1_: (set int))(v_S2_: (set int))(v_ii_: int) =
   true /\
(mem v_S1_ (power integer)) /\
(v_S1_ == (anon_set_1 )) /\
(mem v_S2_ (power integer)) /\
(v_S2_ == (anon_set_2 )) /\
(mem v_ii_ integer)



predicate define5  =
   true



predicate define6  =
   true



predicate define7  =
   true



predicate define8 (v_ii_: int)(v_S1_: (set int))(v_S2_: (set int)) =
   true /\
(mem 5 (diff (union (singleton 5) (union (singleton 4) (union (singleton 1) (union (singleton 1) (union (singleton 2) (union (singleton 3) (singleton 8))))))) (union (singleton 5) (union (singleton 1) (singleton 3))))) /\
(mem v_ii_ (diff v_S1_ v_S2_))



predicate define9  =
   true



predicate define10  =
   true




predicate lh_0_0  =
   true



goal g_0 :
   forall v_S1_: (set int), v_S2_: (set int), v_ii_: int.
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_S1_ v_S2_ v_ii_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_0_0 )
   -> 
   true /\
(mem 5 (diff (union (singleton 5) (union (singleton 4) (union (singleton 1) (union (singleton 1) (union (singleton 2) (union (singleton 3) (singleton 8))))))) (union (singleton 5) (union (singleton 1) (singleton 3)))))



predicate lh_1_0  =
   true /\
(mem 5 (diff (union (singleton 5) (union (singleton 4) (union (singleton 1) (union (singleton 1) (union (singleton 2) (union (singleton 3) (singleton 8))))))) (union (singleton 5) (union (singleton 1) (singleton 3)))))



goal g_1 :
   forall v_S1_: (set int), v_S2_: (set int), v_ii_: int.
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_S1_ v_S2_ v_ii_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_1_0 )
   -> 
   true /\
(mem v_ii_ (diff v_S1_ v_S2_))


end
