predicate define8 (v_S1_: (set int))(v_S2_: (set int))(v_S3_: (set int))(v_rel1_: (set (int,int)))(v_fun1_: (set (int,int)))(v_fun2_: (set (int,int)))(v_fun3_: (set (int,int)))(v_ss_: (set (int,int)))(v_empty_seq_: (set (int,int))) =
   true /\
((anon_sigma_1 v_S1_ (anon_set_2 v_S1_ )) >= 0) /\
((anon_sigma_2 v_S2_ (anon_set_3 v_S2_ )) >= 1) /\
((anon_sigma_3 v_S3_ (anon_set_4 v_S3_ )) >= 6) /\
((anon_pi_1 v_S1_ (anon_set_5 v_S1_ )) >= 1) /\
((anon_pi_2 v_S2_ (anon_set_6 v_S2_ )) >= 1) /\
((anon_pi_3 v_S3_ (anon_set_7 v_S3_ )) >= 6) /\
((card v_S1_) >= 0) /\
((card v_S2_) >= 1) /\
((card v_S3_) >= 3) /\
(0 >= (card v_S1_)) /\
(1 >= (card v_S2_)) /\
(3 >= (card v_S3_)) /\
((card v_S1_) >= (card v_S2_)) /\
((min v_S2_) >= 3) /\
((max v_S2_) >= 1) /\
(1 >= (min v_S2_)) /\
(3 >= (max v_S2_)) /\
((max v_S1_) >= (min v_S1_)) /\
((apply v_rel1_ 2) >= 7) /\
(7 >= (apply v_rel1_ 2)) /\
((apply v_fun1_ 1) >= 3) /\
(3 >= (apply v_fun1_ 1)) /\
((apply v_fun2_ 1) >= (apply v_fun3_ 1)) /\
((first v_ss_) >= 7) /\
(7 >= (first v_ss_)) /\
((last v_ss_) >= 21) /\
(21 >= (last v_ss_)) /\
((first v_ss_) >= (last v_ss_)) /\
((size v_ss_) >= 4) /\
(4 >= (size v_ss_)) /\
((size v_empty_seq_) >= 0) /\
(0 >= (size v_empty_seq_))



