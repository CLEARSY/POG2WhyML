theory B_translation
  use bool.Bool
  use int.Int
  use int.Power
  use int.ComputerDivision
    (* See B-Book, section 3.5.7-Arithmetic, Division, p. 164
       and section 3.6-Integers, table p. 173 *)

  use bpo2why_prelude.B_BOOL
  use real.Real
  use bpo2why_prelude.B_REAL
  use bpo2why_prelude.Interval
  use bpo2why_prelude.PowerSet
  use bpo2why_prelude.Relation
  use bpo2why_prelude.Image
  use bpo2why_prelude.Identity
  use bpo2why_prelude.InverseDomRan
  use bpo2why_prelude.Function
  use bpo2why_prelude.Sequence
  use bpo2why_prelude.IsFinite
  use bpo2why_prelude.PowerRelation
  use bpo2why_prelude.Restriction
  use bpo2why_prelude.Overriding
  use bpo2why_prelude.Composition
  use bpo2why_prelude.BList
  use bpo2why_prelude.MinMax
  use bpo2why_prelude.Projection
  use bpo2why_prelude.Iteration
  use bpo2why_prelude.Generalized





predicate define1  =
   true /\
(nat == (Interval.mk 0 b_maxint32_value)) /\
(bounded_int == (Interval.mk b_minint32_value b_maxint32_value))



predicate define2  =
   true



predicate define3  =
   true



predicate define4 (v_aa_: real)(v_bb_: real)(v_cc_: real) =
   true /\
(mem v_aa_ b_real) /\
(mem v_bb_ b_real) /\
(mem v_cc_ b_real)



predicate define5  =
   true



predicate define6  =
   true



predicate define7  =
   true



predicate define8 (v_aa_: real)(v_bb_: real)(v_cc_: real) =
   true /\
(v_aa_ = 0.0) /\
((v_aa_ + v_bb_) = v_cc_) /\
((v_aa_ - v_bb_) = v_cc_) /\
((v_aa_ * v_bb_) = v_cc_) /\
((v_aa_ / v_bb_) = v_cc_)



predicate define9  =
   true



predicate define10  =
   true




predicate lh_0_0  =
   true



goal g_0 :
   forall v_aa_: real, v_bb_: real, v_cc_: real.
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_aa_ v_bb_ v_cc_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_0_0 )
   -> 
   true /\
(v_aa_ = 0.0)



predicate lh_1_0 (v_aa_: real) =
   true /\
(v_aa_ = 0.0)



goal g_1 :
   forall v_aa_: real, v_bb_: real, v_cc_: real.
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_aa_ v_bb_ v_cc_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_1_0 v_aa_)
   -> 
   true /\
((v_aa_ + v_bb_) = v_cc_)



predicate lh_2_0 (v_aa_: real) =
   true /\
(v_aa_ = 0.0)



goal g_2 :
   forall v_aa_: real, v_bb_: real, v_cc_: real.
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_aa_ v_bb_ v_cc_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_2_0 v_aa_)
   -> 
   true /\
((v_aa_ - v_bb_) = v_cc_)



predicate lh_3_0 (v_aa_: real) =
   true /\
(v_aa_ = 0.0)



goal g_3 :
   forall v_aa_: real, v_bb_: real, v_cc_: real.
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_aa_ v_bb_ v_cc_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_3_0 v_aa_)
   -> 
   true /\
((v_aa_ * v_bb_) = v_cc_)



predicate lh_4_0 (v_aa_: real) =
   true /\
(v_aa_ = 0.0)



goal g_4 :
   forall v_aa_: real, v_bb_: real, v_cc_: real.
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_aa_ v_bb_ v_cc_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_4_0 v_aa_)
   -> 
   true /\
((v_aa_ / v_bb_) = v_cc_)


end
