theory B_translation
  use bool.Bool
  use int.Int
  use int.Power
  use int.ComputerDivision
    (* See B-Book, section 3.5.7-Arithmetic, Division, p. 164
       and section 3.6-Integers, table p. 173 *)

  use bpo2why_prelude.B_BOOL
  use real.Real
  use bpo2why_prelude.B_REAL
  use bpo2why_prelude.Interval
  use bpo2why_prelude.PowerSet
  use bpo2why_prelude.Relation
  use bpo2why_prelude.Image
  use bpo2why_prelude.Identity
  use bpo2why_prelude.InverseDomRan
  use bpo2why_prelude.Function
  use bpo2why_prelude.Sequence
  use bpo2why_prelude.IsFinite
  use bpo2why_prelude.PowerRelation
  use bpo2why_prelude.Restriction
  use bpo2why_prelude.Overriding
  use bpo2why_prelude.Composition
  use bpo2why_prelude.BList
  use bpo2why_prelude.MinMax
  use bpo2why_prelude.Projection
  use bpo2why_prelude.Iteration
  use bpo2why_prelude.Generalized





predicate define1  =
   true /\
(nat == (Interval.mk 0 b_maxint32_value)) /\
(bounded_int == (Interval.mk b_minint32_value b_maxint32_value))



predicate define2  =
   true



predicate define3  =
   true


function anon_set_1 : (set (int,int))

axiom anon_set_1_def :
forall v_xx_: int, v_yy_: int .
 mem ((v_xx_),v_yy_)(anon_set_1 ) <-> (mem v_xx_ (Interval.mk 0 2)) /\ (v_yy_ = (v_xx_ + 1))

function anon_lambda_1 : set((int),int)

axiom anon_lambda_1_def :
forall v_xx_: int .
(mem v_xx_ (Interval.mk 0 2))
-> (apply (anon_lambda_1 ) (v_xx_)) = (v_xx_ + 1)


predicate define4 (v_rel1_: (set (int,int)))(v_fun1_: (set (int,int)))(v_fun2_: (set (int,int)))(v_fun3_: (set (int,int)))(v_fun4_: (set (real,real))) =
   true /\
(v_rel1_ == (union (singleton (2 , 7)) (union (singleton (5 , 9)) (union (singleton (2 , 6)) (union (singleton (7 , 9)) (singleton (5 , 3))))))) /\
(mem v_fun1_ (relation integer integer)) /\
((dom v_fun1_) == (Interval.mk 0 2)) /\
((ran v_fun1_) == (Interval.mk 1 3)) /\
(forall v_xx_: int.((mem v_xx_ (dom v_fun1_)) -> ((apply v_fun1_ v_xx_) = (v_xx_ + 1)))) /\
(v_fun2_ == (anon_set_1 )) /\
(v_fun3_ == (anon_lambda_1 )) /\
(mem v_fun4_ (relation b_real b_real))



predicate define5  =
   true



predicate define6  =
   true



predicate define7  =
   true



predicate define8 (v_rel1_: (set (int,int)))(v_fun1_: (set (int,int)))(v_fun2_: (set (int,int)))(v_fun3_: (set (int,int)))(v_fun4_: (set (real,real))) =
   true /\
(mem v_rel1_ ((Interval.mk 0 7) >-> (Interval.mk 0 10))) /\
(mem v_fun1_ ((dom v_fun1_) >-> (ran v_fun1_))) /\
(mem v_fun2_ (integer >-> integer)) /\
(mem v_fun3_ (integer >-> integer)) /\
(mem v_fun4_ (b_real >-> b_real))



predicate define9  =
   true



predicate define10  =
   true




predicate lh_0_0  =
   true



goal g_0 :
   forall v_rel1_: (set (int,int)), v_fun1_: (set (int,int)), v_fun2_: (set (int,int)), v_fun3_: (set (int,int)), v_fun4_: (set (real,real)).
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_rel1_ v_fun1_ v_fun2_ v_fun3_ v_fun4_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_0_0 )
   -> 
   true /\
(mem v_rel1_ ((Interval.mk 0 7) >-> (Interval.mk 0 10)))



predicate lh_1_0 (v_rel1_: (set (int,int))) =
   true /\
(mem v_rel1_ ((Interval.mk 0 7) >-> (Interval.mk 0 10)))



goal g_1 :
   forall v_rel1_: (set (int,int)), v_fun1_: (set (int,int)), v_fun2_: (set (int,int)), v_fun3_: (set (int,int)), v_fun4_: (set (real,real)).
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_rel1_ v_fun1_ v_fun2_ v_fun3_ v_fun4_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_1_0 v_rel1_)
   -> 
   true /\
(mem v_fun1_ ((dom v_fun1_) >-> (ran v_fun1_)))



predicate lh_2_0 (v_rel1_: (set (int,int))) =
   true /\
(mem v_rel1_ ((Interval.mk 0 7) >-> (Interval.mk 0 10)))



goal g_2 :
   forall v_rel1_: (set (int,int)), v_fun1_: (set (int,int)), v_fun2_: (set (int,int)), v_fun3_: (set (int,int)), v_fun4_: (set (real,real)).
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_rel1_ v_fun1_ v_fun2_ v_fun3_ v_fun4_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_2_0 v_rel1_)
   -> 
   true /\
(mem v_fun2_ (integer >-> integer))



predicate lh_3_0 (v_rel1_: (set (int,int))) =
   true /\
(mem v_rel1_ ((Interval.mk 0 7) >-> (Interval.mk 0 10)))



goal g_3 :
   forall v_rel1_: (set (int,int)), v_fun1_: (set (int,int)), v_fun2_: (set (int,int)), v_fun3_: (set (int,int)), v_fun4_: (set (real,real)).
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_rel1_ v_fun1_ v_fun2_ v_fun3_ v_fun4_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_3_0 v_rel1_)
   -> 
   true /\
(mem v_fun3_ (integer >-> integer))



predicate lh_4_0 (v_rel1_: (set (int,int))) =
   true /\
(mem v_rel1_ ((Interval.mk 0 7) >-> (Interval.mk 0 10)))



goal g_4 :
   forall v_rel1_: (set (int,int)), v_fun1_: (set (int,int)), v_fun2_: (set (int,int)), v_fun3_: (set (int,int)), v_fun4_: (set (real,real)).
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_rel1_ v_fun1_ v_fun2_ v_fun3_ v_fun4_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_4_0 v_rel1_)
   -> 
   true /\
(mem v_fun4_ (b_real >-> b_real))


end
