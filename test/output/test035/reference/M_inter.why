theory B_translation
  use bool.Bool
  use int.Int
  use int.Power
  use int.ComputerDivision
    (* See B-Book, section 3.5.7-Arithmetic, Division, p. 164
       and section 3.6-Integers, table p. 173 *)

  use bpo2why_prelude.B_BOOL
  use real.Real
  use bpo2why_prelude.B_REAL
  use bpo2why_prelude.Interval
  use bpo2why_prelude.PowerSet
  use bpo2why_prelude.Relation
  use bpo2why_prelude.Image
  use bpo2why_prelude.Identity
  use bpo2why_prelude.InverseDomRan
  use bpo2why_prelude.Function
  use bpo2why_prelude.Sequence
  use bpo2why_prelude.IsFinite
  use bpo2why_prelude.PowerRelation
  use bpo2why_prelude.Restriction
  use bpo2why_prelude.Overriding
  use bpo2why_prelude.Composition
  use bpo2why_prelude.BList
  use bpo2why_prelude.MinMax
  use bpo2why_prelude.Projection
  use bpo2why_prelude.Iteration
  use bpo2why_prelude.Generalized





predicate define1  =
   true /\
(nat == (Interval.mk 0 b_maxint32_value)) /\
(bounded_int == (Interval.mk b_minint32_value b_maxint32_value))



predicate define2  =
   true



predicate define3  =
   true



predicate define4 (v_S1_: (set (set int)))(v_S2_: (set real))(v_xx_: int)(v_yy_: real) =
   true /\
(mem v_S1_ (power (power integer))) /\
(v_S1_ == (union (singleton (union (singleton 5) (singleton 4))) (union (singleton (singleton 1)) (singleton (union (singleton 1) (union (singleton 2) (singleton 3))))))) /\
(mem v_S2_ (power b_real)) /\
(v_S2_ == (union (singleton 4.1) (union (singleton 2.3) (singleton 0.2)))) /\
(mem v_xx_ integer) /\
(mem v_yy_ b_real)



predicate define5  =
   true



predicate define6  =
   true



predicate define7  =
   true


function anon_inter_1 (v_S1_: (set (set int))): (set int)

axiom anon_inter_1_def :
forall v_S1_: (set (set int)), xx : int .
mem xx (anon_inter_1 v_S1_)
<-> (forall v_val_: (set int).
((mem v_val_ v_S1_))
-> (mem xx (v_val_)))


predicate define8 (v_xx_: int)(v_S1_: (set (set int)))(v_yy_: real)(v_S2_: (set real)) =
   true /\
(mem v_xx_ (anon_inter_1 v_S1_)) /\
(mem v_yy_ v_S2_)



predicate define9  =
   true



predicate define10  =
   true




predicate lh_0_0  =
   true


function anon_inter_2 (v_S1_: (set (set int))): (set int)

axiom anon_inter_2_def :
forall v_S1_: (set (set int)), xx : int .
mem xx (anon_inter_2 v_S1_)
<-> (forall v_val_: (set int).
((mem v_val_ v_S1_))
-> (mem xx (v_val_)))

goal g_0 :
   forall v_S1_: (set (set int)), v_S2_: (set real), v_xx_: int, v_yy_: real.
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_S1_ v_S2_ v_xx_ v_yy_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_0_0 )
   -> 
   true /\
(mem v_xx_ (anon_inter_2 v_S1_))


function anon_inter_3 (v_S1_: (set (set int))): (set int)

axiom anon_inter_3_def :
forall v_S1_: (set (set int)), xx : int .
mem xx (anon_inter_3 v_S1_)
<-> (forall v_val_: (set int).
((mem v_val_ v_S1_))
-> (mem xx (v_val_)))


predicate lh_1_0 (v_xx_: int)(v_S1_: (set (set int))) =
   true /\
(mem v_xx_ (anon_inter_3 v_S1_))



goal g_1 :
   forall v_S1_: (set (set int)), v_S2_: (set real), v_xx_: int, v_yy_: real.
   (define1 ) /\ (define2 ) /\ (define9 ) /\ (define4 v_S1_ v_S2_ v_xx_ v_yy_) /\ (define5 ) /\ (define6 ) /\ (define3 ) /\ (define7 ) /\ (lh_1_0 v_xx_ v_S1_)
   -> 
   true /\
(mem v_yy_ v_S2_)


end
