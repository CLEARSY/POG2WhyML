predicate define1  =
   true /\
(nat == (Interval.mk 0 b_maxint32_value)) /\
(bounded_int == (Interval.mk b_minint32_value b_maxint32_value))



predicate define2  =
   true



predicate define3  =
   true



predicate define4 (v_S1_: (set int))(v_S2_: (set int))(v_S3_: (set int)) =
   true /\
(mem v_S1_ (power integer)) /\
(mem v_S2_ (power integer)) /\
(mem v_S3_ (power integer)) /\
(v_S1_ == (empty : (set int))) /\
(v_S2_ == (singleton 1)) /\
(v_S3_ == (union (singleton 1) (union (singleton 2) (singleton 3))))



predicate define5  =
   true



predicate define6  =
   true



predicate define7  =
   true


function anon_set_1 (v_S1_: (set int)): (set int)

axiom anon_set_1_def :
forall v_S1_: (set int), v_val_: int .
 mem (v_val_)(anon_set_1 v_S1_ ) <-> (mem v_val_ v_S1_)

function anon_sigma_1 (v_S1_: (set int)) (p_sigma_1 : set(int)) : int

axiom anon_sigma_1_def0 : forall v_S1_: (set int). anon_sigma_1 v_S1_ (empty : set(int)) = 0 

axiom anon_sigma_1_def_ind : forall v_S1_: (set int), p_sigma_1 : set(int), v_val_: int. mem (v_val_) p_sigma_1 -> anon_sigma_1 v_S1_ p_sigma_1 = anon_sigma_1 v_S1_ (diff p_sigma_1 (singleton (v_val_))) + v_val_
